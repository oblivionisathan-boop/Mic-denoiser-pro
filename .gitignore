__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales (Si alguien crea uno para probar tu código, no se subirá)
venv/
env/
.env

# Basura del sistema operativo (Windows y Linux)
Thumbs.db
Desktop.ini
.DS_Store
*~

# Archivos de empaquetado (Por si en el futuro lo conviertes en .exe o binario)
build/
dist/
*.spec
